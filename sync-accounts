#!/usr/bin/env ruby
# frozen_string_literal: true

VERSION = '0.2.2'

require 'uri'
require 'yaml'
require 'net/http'
require 'net/https'
require 'fileutils'

def http_get(url)
  uri = URI.parse(url)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = uri.scheme == 'https'

  response = http.request(Net::HTTP::Get.new(uri.request_uri))
  unless response.is_a?(Net::HTTPOK)
    abort("failed to fetch #{url}: HTTP #{response.code} #{response.message}")
  end
  response.body
end

$key_cache = {}
def github_keys(user)
  $key_cache[user] ||= http_get("https://github.com/#{user}.keys").split("\n").reject(&:empty?)
end

def read_permissions_from_url(url)
  YAML.safe_load(http_get(url))
end

def read_permissions(config_file_or_url)
  permissions = { 'apps' => {}, 'users' => {} }

  yaml = if File.exist?(config_file_or_url)
    contents = File.read(config_file_or_url)
    if contents.strip.empty?
      abort("permissions config file \"#{config_file_or_url}\" is empty")
    end
    
    configs = YAML.safe_load(contents)
    configs['url'] ? read_permissions_from_url(configs['url']) : configs
  elsif config_file_or_url =~ URI::regexp
    read_permissions_from_url(config_file_or_url)
  else
    abort("permissions config file \"#{config_file_or_url}\" not found")
  end

  if !yaml.is_a?(Hash) ||
     (!yaml['users'].nil? && !yaml['users'].is_a?(Array)) ||
     (!yaml['apps'].nil? && !yaml['apps'].is_a?(Hash))
    abort("permissions config syntax is incorrect")
  end

  users = yaml['users'] || []
  apps = yaml['apps'] || {}

  if users.empty? && apps.empty?
    abort("permissions config is missing 'users' or 'apps' — refusing to sync")
  end

  users.each do |user|
    permissions['users'][user] = github_keys(user)
  end

  apps.each do |app, app_users|
    permissions['apps'][app] = app_users.map{|u| github_keys(u) }.flatten
  end

  permissions
end

def uid_range
  return $uid_range if defined?($uid_range)
  min, max = 1000, 60000
  if File.exist?('/etc/login.defs')
    File.read('/etc/login.defs').each_line do |line|
      min = $1.to_i if line =~ /^\s*UID_MIN\s+(\d+)/
      max = $1.to_i if line =~ /^\s*UID_MAX\s+(\d+)/
    end
  end
  $uid_range = (min..max)
end

def shells
  return $shells if defined?($shells)
  $shells = File.read('/etc/shells').lines.map(&:strip).select { |l| !l.empty? && !l.start_with?('#') }
end

def passwd_entries
  $passwd_entries ||= File.read('/etc/passwd').lines.reduce([]) do |a, u|
    if u =~ /^([^:]+):[^:]*:(\d+):[^:]*:[^:]*:([^:]+):([^:]+)$/
      u = {name: $1.strip, uid: $2.to_i, home: $3.strip, shell: $4.strip}
      a << u if uid_range.include?(u[:uid]) && shells.include?(u[:shell])
    end
    a
  end
end

def system_users
  passwd_entries.select{|u| u[:home].start_with?('/home') }
end

def system_apps
  passwd_entries.select{|u| u[:home].start_with?('/srv') }
end

AUTHORIZED_KEYS_DIR = '/etc/ssh/authorized_keys'

def validate_user_name!(name)
  raise "invalid user name '#{name}'" unless name =~ /^[a-z][-a-z0-9]*$/
end

# GitHub usernames may start with a digit (e.g. "1password") but Linux
# usernames must start with a letter; strip leading digits to get the
# local system username.
def local_user_name(github_username)
  github_username.sub(/^[0-9]+/, '')
end

def run!(*cmd)
  abort("command failed (exit #{$?.exitstatus}): #{cmd.join(' ')}") unless system(*cmd)
end

def add_system_user(name)
  validate_user_name!(name)
  run!('/usr/sbin/useradd', '--create-home', name)
  run!('/usr/sbin/usermod', '-a', '-G', 'wheel', name)
  $passwd_entries = nil
end

def remove_system_user(name)
  validate_user_name!(name)
  run!('/usr/bin/userdel', '--remove', name)
  FileUtils.rm_f(File.join(AUTHORIZED_KEYS_DIR, name))
  $passwd_entries = nil
end

def write_authorized_keys(user, keys)
  validate_user_name!(user)
  FileUtils.mkdir_p(AUTHORIZED_KEYS_DIR, mode: 0755)
  filename = File.join(AUTHORIZED_KEYS_DIR, user)
  File.open(filename, 'w', 0644) do |file|
    keys.each {|k| file.puts(k) }
  end
end

if ARGV[0] == '-v' || ARGV[0] == '--version'
  puts "sync-accounts #{VERSION}"
  exit
end

permissions = read_permissions(ARGV[0] || '/etc/sync-accounts.conf')

# Create missing users
system_usernames = system_users.map{|su| su[:name]}
permission_usernames = permissions['users'].keys.map{|k| local_user_name(k) }
permission_usernames.each do |user|
  next if system_usernames.include?(user)
  puts "adding user #{user}"
  add_system_user(user)
end

# Removed old users
system_usernames.each do |user|
  next if permission_usernames.include?(user)
  puts "removing user #{user}"
  remove_system_user(user)
end

# Write user ssh keys
system_users.each do |su|
  key = permissions['users'].keys.find {|k| local_user_name(k) == su[:name] }
  puts "writing authorized_keys for #{su[:name]}"
  write_authorized_keys(su[:name], permissions['users'][key])
end

# Write app ssh keys
system_apps.each do |su|
  next if !permissions['apps'][su[:name]]
  puts "writing authorized_keys for #{su[:name]}"
  write_authorized_keys(su[:name], permissions['apps'][su[:name]])
end
